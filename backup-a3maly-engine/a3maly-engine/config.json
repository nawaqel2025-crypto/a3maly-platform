{
  "watchMode": true,
  "fullRegen": false,
  "autoFix": true,
  "autoGenerate": true,
  "autoCleanup": true,

  "paths": {
    "root": ".",
    "src": "src",
    "app": "app",
    "api": "app/api",
    "components": "components",
    "lib": "lib",
    "modules": "src/modules"
  },

  "aliases": {
    "@": "src",
    "@components": "components",
    "@lib": "lib",
    "@api": "app/api"
  },

  "generator": {
    "createMissingFiles": true,
    "createCrudModules": true,
    "createApiRoutes": true,
    "createModulePages": true,
    "placeholderComment": "// Auto-generated by A3MALY ENGINE"
  },

  "fixer": {
    "fixBrokenImports": true,
    "convertRelativeToAlias": true,
    "fixTSConfigPaths": true,
    "fixNextConfig": true,
    "createMissingDirectories": true
  },

  "regenerator": {
    "rebuildAppStructure": true,
    "rebuildApiStructure": true,
    "rebuildLibStructure": true,
    "cleanupTempFiles": true
  }
}
