generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model ReceiptVoucher {
  id          Int             @id @default(autoincrement())
  voucherNo   String
  date        DateTime
  paymentType String
  notes       String?
  createdAt   DateTime        @default(now())

  entries     ReceiptEntry[]
}

model ReceiptEntry {
  id        Int             @id @default(autoincrement())
  account   String
  debit     Float
  credit    Float

  voucherId Int
  voucher   ReceiptVoucher  @relation(fields: [voucherId], references: [id])
}

