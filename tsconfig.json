{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./",
    "baseUrl": "./",
    "paths": {
      "@core/*": [
        "packages/core/*"
      ],
      "@domain/*": [
        "packages/domain/*"
      ],
      "@engines/*": [
        "packages/engines/*"
      ],
      "@infra/*": [
        "infra/*"
      ]
    },
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "src",
    "packages",
    "infra",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
