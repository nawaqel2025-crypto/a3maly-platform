{
  "extends": "./tsconfig.json",
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "types/**/*.ts",
    "types/**/*.d.ts",
    "src/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "backup-a3maly-engine",
    "tools",
    "infra",
    "packages",
    "src/app",
    "src/modules",
    "src/services"
  ]
}
